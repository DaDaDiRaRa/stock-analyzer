# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Naver Open API (뉴스 검색)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# 서버 포트 (Cloud Run은 자동으로 PORT=8080 주입)
PORT=3001

# Finnhub (주식 뉴스)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage (뉴스 감성 분석)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# DART 전자공시 (한국 기업 공시)
DART_API_KEY=your_dart_api_key_here

# NewsAPI.org (한국어 포함 글로벌 뉴스)
NEWS_API_KEY=your_newsapi_key_here

# Google Sheets 연동 (포트폴리오 영구 저장)
GOOGLE_SHEET_ID=your_google_sheet_id_here
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("C:\경로\key.json"))
GOOGLE_SERVICE_ACCOUNT_KEY=your_base64_encoded_service_account_json
